version: 1.0
runtime: python3
build:
  commands:
    build:
      - echo "Installing dependencies for BoatId FastAPI backend..."
      - pip install -r requirements.txt
run:
  runtime-version: 3.11
  command: uvicorn main:app --host 0.0.0.0 --port 8000
  network:
    port: 8000
    env: PORT
  env:
    # Database Configuration
    - name: AWS_RDS_PASSWORD
      value: "YOUR_RDS_PASSWORD"
    - name: AWS_RDS_ENDPOINT
      value: "your-rds-endpoint.region.rds.amazonaws.com"
    - name: AWS_RDS_MASTER_USERNAME
      value: "your-username"
    - name: AWS_RDS_PORT
      value: "5432"
    - name: AWS_RDS_DATABASE
      value: "your-database"
    - name: AWS_RDS_URL
      value: "postgresql://username:password@host:port/database"
    
    # S3 Configuration
    - name: AWS_BUCKET_NAME
      value: "your-s3-bucket-name"
    - name: AWS_REGION
      value: "your-aws-region"
    
    # Application Configuration
    - name: AUTH_SECRET_KEY
      value: "your-secret-key-here"
    - name: ADMIN_USERNAME
      value: "admin"
    - name: ADMIN_PASSWORD
      value: "your-admin-password"
    - name: ADMIN_EMAIL
      value: "admin@yourdomain.com"
    
    # Anthropic API Key
    - name: ANTHROPIC_API_KEY
      value: "your-anthropic-api-key"