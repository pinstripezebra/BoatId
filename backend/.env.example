# BoatId Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database Configuration (AWS RDS PostgreSQL)
AWS_RDS_PASSWORD=YOUR_RDS_PASSWORD
AWS_RDS_ENDPOINT=your-rds-endpoint.region.rds.amazonaws.com
AWS_RDS_MASTER_USERNAME=your-username
AWS_RDS_PORT=5432
AWS_RDS_DATABASE=your-database
AWS_RDS_URL=postgresql://username:password@host:port/database

# S3 Configuration
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-west-2

# Authentication
AUTH_SECRET_KEY=your-secret-key-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password
ADMIN_EMAIL=admin@yourdomain.com

# Anthropic API Key (for boat identification)
ANTHROPIC_API_KEY=your-anthropic-api-key
